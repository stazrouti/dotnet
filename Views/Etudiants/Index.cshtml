@model EtudiantIndexViewModel

@{
    ViewData["Title"] = "Etudiants";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bx bx-group me-2"></i>Liste des etudiants</h5>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-sm btn-primary"><i class="bx bx-plus me-1"></i>Nouvel etudiant</a>
        }
    </div>
    <div class="card-body">
        <form method="get" class="mb-3">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Rechercher par CIN, matricule, nom, prenom ou email..." value="@Model.Search" />
                <button class="btn btn-primary" type="submit"><i class="bx bx-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bx bx-reset"></i>Reinitialiser</a>
            </div>
        </form>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model.Etudiants?.Any() == true)
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>CIN</th>
                            <th>Matricule</th>
                            <th>Nom</th>
                            <th>Prenom</th>
                            <th>Email</th>
                            <th>Niveau</th>
                            <th>Filiere</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var etudiant in Model.Etudiants)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-info">@etudiant.Cin</span>
                                </td>
                                <td>@etudiant.Matricule</td>
                                <td>@etudiant.Nom</td>
                                <td>@etudiant.Prenom</td>
                                <td>@etudiant.Email</td>
                                <td>@etudiant.Niveau</td>
                                <td>@etudiant.Filiere</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@etudiant.Cin" class="btn btn-sm btn-info" title="Voir les details"><i class="bx bx-show"></i></a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@etudiant.Cin" class="btn btn-sm btn-warning" title="Modifier"><i class="bx bx-edit"></i></a>
                                            <a asp-action="Delete" asp-route-id="@etudiant.Cin" class="btn btn-sm btn-danger" title="Supprimer"><i class="bx bx-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info" role="alert">
                <i class="bx bx-info-circle me-2"></i>Aucun etudiant n'a ete trouve.
            </div>
        }
    </div>
</div>
