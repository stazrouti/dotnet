@model LivreDetailsViewModel

@{
    ViewData["Title"] = "Details livre";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bx bx-book-reader me-2"></i>@Model.Livre.Titre</h5>
        <div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Livre.Numinventaire" class="btn btn-outline-primary btn-sm">Modifier</a>
            }
            @if (User.IsInRole("User") && Model.CanReserve)
            {
                <a asp-action="Reserve" asp-route-id="@Model.Livre.Numinventaire" class="btn btn-success btn-sm">Reserver</a>
            }
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Retour</a>
        </div>
    </div>
    <div class="card-body">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success" role="alert">@success</div>
        }

        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger" role="alert">@error</div>
        }

        @if (User.IsInRole("User") && !Model.CanReserve && !string.IsNullOrWhiteSpace(Model.ReservationBlockedReason))
        {
            <div class="alert alert-warning" role="alert">
                @Model.ReservationBlockedReason
            </div>
        }

        <dl class="row mb-0">
            <dt class="col-sm-3">Inventaire</dt>
            <dd class="col-sm-9">@Model.Livre.Numinventaire</dd>

            <dt class="col-sm-3">ISBN</dt>
            <dd class="col-sm-9">@Model.Livre.Isbn</dd>

            <dt class="col-sm-3">Auteur</dt>
            <dd class="col-sm-9">@Model.Livre.Auteur</dd>

            <dt class="col-sm-3">Editeur</dt>
            <dd class="col-sm-9">@Model.Livre.Editeur</dd>

            <dt class="col-sm-3">Date publication</dt>
            <dd class="col-sm-9">@Model.Livre.Datepublication</dd>

            <dt class="col-sm-3">Date arrivage</dt>
            <dd class="col-sm-9">@Model.Livre.Datearrivage</dd>

            <dt class="col-sm-3">Cote</dt>
            <dd class="col-sm-9">@Model.Livre.Cote</dd>

            <dt class="col-sm-3">Resume</dt>
            <dd class="col-sm-9">@Model.Livre.Résumé</dd>
        </dl>

        <hr />

        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0">Disponibilite et reservations</h6>
            @if (User.IsInRole("User"))
            {
                <span class="badge bg-secondary">@Model.CurrentReservationCount / @Model.MaxReservationCount reservations</span>
            }
        </div>

        @if (!Model.Reservations.Any())
        {
            <div class="alert alert-success mb-0" role="alert">
                Aucun booking actif ou planifie. Le livre est disponible sur les prochains jours.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Debut</th>
                            <th>Fin</th>
                            <th>Statut</th>
                            @if (User.IsInRole("User"))
                            {
                                <th class="text-end">Action</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reservation in Model.Reservations)
                        {
                            <tr>
                                <td>@reservation.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@reservation.EndDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (reservation.Status == ReservationStatus.Active)
                                    {
                                        <span class="badge bg-danger">Active</span>
                                    }
                                    else if (reservation.Status == ReservationStatus.Cancelled)
                                    {
                                        <span class="badge bg-secondary">Annulee</span>
                                    }
                                    else if (reservation.Status == ReservationStatus.Reserved)
                                    {
                                        <span class="badge bg-warning text-dark">Reservee</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Retournee</span>
                                    }
                                </td>
                                @if (User.IsInRole("User"))
                                {
                                    <td class="text-end">
                                        @if (reservation.CanCancel)
                                        {
                                            <form asp-action="CancelReservation" asp-route-id="@Model.Livre.Numinventaire" asp-route-reservationId="@reservation.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Confirmer l\'annulation de cette reservation ?');">Annuler</button>
                                            </form>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">
            <i class="bx bx-star me-2"></i>
            Evaluations et avis
            @if (Model.Reviews.TotalReviews > 0)
            {
                <span class="badge bg-primary">@Model.Reviews.AverageRating?.ToString("F1") / 5</span>
            }
        </h6>
        <small class="text-muted">@Model.Reviews.TotalReviews evaluations</small>
    </div>
    <div class="card-body">
        <!-- Review Form for eligible students -->
        @if (User.IsInRole("User") && Model.Reviews.CanCurrentUserReview)
        {
            <div class="card bg-light mb-3">
                <div class="card-header">
                    <h6 class="mb-0">Ajouter une evaluation</h6>
                </div>
                <div class="card-body">
                    <form asp-action="CreateReview" asp-route-id="@Model.Livre.Numinventaire" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Note <span class="text-danger">*</span></label>
                            <select name="note" class="form-select" required>
                                <option value="">Choisir une note</option>
                                <option value="1">1 - Tres mauvais</option>
                                <option value="2">2 - Mauvais</option>
                                <option value="3">3 - Moyen</option>
                                <option value="4">4 - Bon</option>
                                <option value="5">5 - Excellent</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Commentaire (optionnel)</label>
                            <textarea name="commentaire" class="form-control" rows="3" placeholder="Partagez votre avis sur ce livre..." maxlength="500"></textarea>
                            <small class="form-text text-muted">Max 500 caracteres</small>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Soumettre evaluation</button>
                    </form>
                </div>
            </div>
        }

        <!-- Student's existing review -->
        @if (User.IsInRole("User") && Model.Reviews.CurrentUserExistingReview != null)
        {
            <div class="card border-primary mb-3">
                <div class="card-header bg-primary bg-opacity-10">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong class="text-dark">Votre evaluation</strong>
                        <div>
                            <button type="button" id="toggleEditReviewBtn" class="btn btn-sm btn-outline-secondary">Modifier</button>
                            <form asp-action="DeleteReview" asp-route-id="@Model.Livre.Numinventaire" asp-route-reviewId="@Model.Reviews.CurrentUserExistingReview.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer cette evaluation ?');">Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        @for (int i = 0; i < Model.Reviews.CurrentUserExistingReview.Note; i++)
                        {
                            <i class="bx bxs-star text-warning"></i>
                        }
                        @for (int i = Model.Reviews.CurrentUserExistingReview.Note; i < 5; i++)
                        {
                            <i class="bx bx-star text-muted"></i>
                        }
                        <span class="badge bg-warning text-dark">@Model.Reviews.CurrentUserExistingReview.Note / 5</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Reviews.CurrentUserExistingReview.Commentaire))
                    {
                        <p class="mb-2">@Model.Reviews.CurrentUserExistingReview.Commentaire</p>
                    }
                    <small class="text-muted">
                        @if (Model.Reviews.CurrentUserExistingReview.UpdatedAt.HasValue)
                        {
                            <span>Modifiee le @Model.Reviews.CurrentUserExistingReview.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                        }
                        else
                        {
                            <span>Crée le @Model.Reviews.CurrentUserExistingReview.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        }
                    </small>

                    <!-- Edit form (hidden by default) -->
                    <div id="editReviewForm" class="mt-3 d-none">
                        <form asp-action="UpdateReview" asp-route-id="@Model.Livre.Numinventaire" asp-route-reviewId="@Model.Reviews.CurrentUserExistingReview.Id" method="post" class="card card-body bg-light">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label">Note</label>
                                <select name="note" class="form-select" required>
                                    <option value="1" selected="@(Model.Reviews.CurrentUserExistingReview.Note == 1 ? "selected" : null)">1 - Tres mauvais</option>
                                    <option value="2" selected="@(Model.Reviews.CurrentUserExistingReview.Note == 2 ? "selected" : null)">2 - Mauvais</option>
                                    <option value="3" selected="@(Model.Reviews.CurrentUserExistingReview.Note == 3 ? "selected" : null)">3 - Moyen</option>
                                    <option value="4" selected="@(Model.Reviews.CurrentUserExistingReview.Note == 4 ? "selected" : null)">4 - Bon</option>
                                    <option value="5" selected="@(Model.Reviews.CurrentUserExistingReview.Note == 5 ? "selected" : null)">5 - Excellent</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Commentaire</label>
                                <textarea name="commentaire" class="form-control" rows="3" maxlength="500">@Model.Reviews.CurrentUserExistingReview.Commentaire</textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">Mettre a jour</button>
                        </form>
                    </div>
                </div>
            </div>
        }

        <!-- All reviews list -->
        @if (Model.Reviews.Reviews.Any())
        {
            <div>
                <h6 class="mb-3">Avis des autres etudiants</h6>
                @foreach (var review in Model.Reviews.Reviews)
                {
                    @if (User.IsInRole("User") && Model.Reviews.CurrentUserExistingReview?.Id == review.Id)
                    {
                        continue;
                    }

                    <div class="card mb-2">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="mb-2">
                                        @for (int i = 0; i < review.Note; i++)
                                        {
                                            <i class="bx bxs-star text-warning"></i>
                                        }
                                        @for (int i = review.Note; i < 5; i++)
                                        {
                                            <i class="bx bx-star text-muted"></i>
                                        }
                                        <span class="badge bg-warning text-dark ms-2">@review.Note / 5</span>
                                    </div>
                                    <p class="mb-2 small">
                                        <strong>@review.AuthorName</strong>
                                    </p>
                                    @if (!string.IsNullOrWhiteSpace(review.Commentaire))
                                    {
                                        <p class="mb-2">@review.Commentaire</p>
                                    }
                                    <small class="text-muted">
                                        @if (review.UpdatedAt.HasValue)
                                        {
                                            <span>Modifiee le @review.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                                        }
                                        else
                                        {
                                            <span>Crée le @review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                        }
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!Model.Reviews.CanCurrentUserReview || User.IsInRole("Admin"))
        {
            <div class="alert alert-info mb-0">
                Aucune evaluation pour ce livre. Soyez le premier a evaluer !
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var toggleBtn = document.getElementById('toggleEditReviewBtn');
            var editForm = document.getElementById('editReviewForm');

            if (!toggleBtn || !editForm) {
                return;
            }

            toggleBtn.addEventListener('click', function () {
                editForm.classList.toggle('d-none');
                toggleBtn.textContent = editForm.classList.contains('d-none') ? 'Modifier' : 'Fermer';
            });
        })();
    </script>
}