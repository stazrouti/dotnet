@using Bibliotheque.Areas.Etudiant.DTOs
@model ProfileViewModel

@{
    if (User.IsInRole("Etudiant"))
        Layout = "~/Areas/Etudiant/Views/Shared/_Layout.cshtml";
    else
        Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["Title"] = "Mon profil";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bx bx-user me-2"></i>Mon profil</h5>
        <a asp-action="ChangePassword" class="btn btn-outline-primary btn-sm">Changer le mot de passe</a>
    </div>
    <div class="card-body">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success" role="alert">@success</div>
        }

        <form asp-action="Profile" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="NomComplet" class="form-label"></label>
                <input asp-for="NomComplet" class="form-control" />
                <span asp-validation-for="NomComplet" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label"></label>
                <input asp-for="Role" class="form-control" readonly />
            </div>

            <button type="submit" class="btn btn-primary">Enregistrer</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}