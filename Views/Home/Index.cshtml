@model HomeDashboardViewModel

@{
    ViewData["Title"] = "Tableau de bord";
}

<div class="text-center">
    <h1 class="display-4">Tableau de bord</h1>
</div>

@if (Model.ShowEtudiantSummary)
{
    <div class="mt-3 text-end">
        <a asp-controller="Account" asp-action="Dashboard" class="btn btn-sm btn-outline-primary">
            Voir mes reservations
        </a>
    </div>
    <div class="row g-3 mt-1">
        <div class="col-md-3 col-6">
            <div class="card border-primary h-100">
                <div class="card-body">
                    <div class="small text-muted">Mes reservations aujourd'hui</div>
                    <div class="fs-4 fw-bold text-primary">@Model.TodayReservationsCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-danger h-100">
                <div class="card-body">
                    <div class="small text-muted">A rendre aujourd'hui</div>
                    <div class="fs-4 fw-bold text-danger">@Model.DueTodayCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-warning h-100">
                <div class="card-body">
                    <div class="small text-muted">A rendre cette semaine</div>
                    <div class="fs-4 fw-bold text-warning">@Model.DueThisWeekCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-info h-100">
                <div class="card-body">
                    <div class="small text-muted">Quota disponible</div>
                    <div class="fs-4 fw-bold text-info">@Model.RemainingQuota / @Model.MaxReservationCount</div>
                </div>
            </div>
        </div>
    </div>


}
