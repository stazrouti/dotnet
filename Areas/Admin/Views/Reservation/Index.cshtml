@using Bibliotheque.Areas.Admin.DTOs
@model ReservationVM

@{
    ViewData["Title"] = "Gestion des Réservations";
}

<div class="container mt-4">

    <div class="card mb-4 p-2">
        <div class="card-header">
            <h2 class="mb-4">📚 Gestion des Réservations</h2>
        </div>
        <div class="card-body p-0">
            <!-- 🔍 SEARCH -->
            <form method="get" class="mb-3 d-flex">
                <input type="text" name="search" value="@Model.SearchTerm"
                       class="form-control me-2"
                       placeholder="Rechercher par CIN ou Livre..." />

                <button type="submit" class="btn btn-primary">Rechercher</button>
            </form>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Étudiant</th>
                            <th>Livre</th>
                            <th>Date Emprunt</th>
                            <th>Date Retour</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Reservations)
                        {
                            <tr>
                                <td>@item.CinNavigation.Nom</td>
                                <td>@item.NuminvNavigation.Titre</td>
                                <td>@item.Dateemprunt?.ToShortDateString()</td>
                                <td>@(item.Dateretour?.ToShortDateString() ?? "-")</td>

                                <td>
                                    @if (item.Estretour != null)
                                    {
                                        <span class="badge bg-success">Retourné</span>
                                    }
                                    else if (item.IsLate)
                                    {
                                        <span class="badge bg-danger">En retard</span>
                                    }
                                    else if (item.CanCancel == false)
                                    {
                                        <span class="badge bg-info">Confirmée</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">En cours</span>
                                    }
                                </td>

                                <td>
                                    @if (item.CanCancel == true)
                                    {
                                        <a asp-action="Confirm" asp-route-id="@item.Id"
                                           class="btn btn-info btn-sm">
                                            Confirmer
                                        </a>
                                    }

                                    @if (item.Estretour == null)
                                    {
                                        <a asp-action="Return" asp-route-id="@item.Id"
                                           class="btn btn-success btn-sm">
                                            Retourner
                                        </a>
                                    }

                                    @if (item.CanCancel && !item.IsLate)
                                    {
                                        <a asp-action="Cancel" asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm">
                                            Annuler
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary btn-sm" disabled
                                                title="Impossible d'annuler après la date limite">
                                            Annulation bloquée
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- 📄 PAGINATION -->
            <nav class="mt-2">
                <ul class="pagination">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@Model.SearchTerm">
                                @i
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>

    



</div>