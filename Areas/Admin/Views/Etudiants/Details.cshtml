@using Bibliotheque.Areas.Admin.DTOs
@model EtudiantDetailsViewModel

@{
    ViewData["Title"] = "Details de l'etudiant";
}

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bx bx-user me-2"></i>Informations de l'etudiant</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">CIN:</label>
                        <p>@Model.Etudiant.Cin</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Matricule:</label>
                        <p>@Model.Etudiant.Matricule</p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nom:</label>
                        <p>@Model.Etudiant.Nom</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Prenom:</label>
                        <p>@Model.Etudiant.Prenom</p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Email:</label>
                        <p>
                            @if (!string.IsNullOrEmpty(Model.Etudiant.Email))
                            {
                                <a href="mailto:@Model.Etudiant.Email">@Model.Etudiant.Email</a>
                            }
                            else
                            {
                                <span class="text-muted">Non fourni</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Telephone:</label>
                        <p>
                            @if (!string.IsNullOrEmpty(Model.Etudiant.Tel))
                            {
                                <a href="tel:@Model.Etudiant.Tel">@Model.Etudiant.Tel</a>
                            }
                            else
                            {
                                <span class="text-muted">Non fourni</span>
                            }
                        </p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Niveau:</label>
                        <p>@Model.Etudiant.Niveau</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Filiere:</label>
                        <p>@Model.Etudiant.Filiere</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Etudiant.Rfid))
                {
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">RFID:</label>
                            <p>@Model.Etudiant.Rfid</p>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Etudiant.Qr))
                {
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Code QR:</label>
                            <p>@Model.Etudiant.Qr</p>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Etudiant.Commentaire))
                {
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Commentaire:</label>
                            <p>@Model.Etudiant.Commentaire</p>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Etudiant.Observation))
                {
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Observation:</label>
                            <p>@Model.Etudiant.Observation</p>
                        </div>
                    </div>
                }

                <div class="row">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Date de creation:</label>
                        <p>@Model.Etudiant.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <hr />
                    <a asp-action="Edit" asp-route-id="@Model.Etudiant.Cin" class="btn btn-warning me-2"><i class="bx bx-edit me-1"></i>Modifier</a>
                    <a asp-action="Delete" asp-route-id="@Model.Etudiant.Cin" class="btn btn-danger"><i class="bx bx-trash me-1"></i>Supprimer</a>
                }
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bx bx-arrow-back me-1"></i>Retour</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        @if (Model.ActiveLoans?.Any() == true)
        {
            <div class="card mb-4">
                <div class="card-header bg-warning">
                    <h5 class="mb-0"><i class="bx bx-book me-2"></i>Emprunts actifs (@Model.ActiveLoans.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group">
                        @foreach (var loan in Model.ActiveLoans.Take(5))
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@loan.NuminvNavigation?.Titre</h6>
                                    <small>@loan.Dateemprunt?.ToString("dd/MM/yyyy")</small>
                                </div>
                                <small class="text-muted">ISBN: @loan.NuminvNavigation?.Isbn</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @if (Model.RecentVisits?.Any() == true)
        {
            <div class="card">
                <div class="card-header bg-info">
                    <h5 class="mb-0"><i class="bx bx-calendar me-2"></i>Visites recentes (@Model.RecentVisits.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group">
                        @foreach (var visit in Model.RecentVisits.Take(5))
                        {
                            <div class="list-group-item">
                                <small class="text-muted">@visit.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
