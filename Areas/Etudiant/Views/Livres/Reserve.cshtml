@using Bibliotheque.Areas.Etudiant.DTOs
@model LivreReserveViewModel

@{
    ViewData["Title"] = "Reserver un livre";
    var today = DateTime.UtcNow.Date;
    var minReservationDate = Model.BookDateArrivage?.ToDateTime(TimeOnly.MinValue).Date ?? today;
    if (minReservationDate < today)
    {
        minReservationDate = today;
    }
    var minReservationDateValue = minReservationDate.ToString("yyyy-MM-dd");
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bx bx-calendar me-2"></i>Reservation: @Model.Titre</h5>
        <a asp-action="Details" asp-route-id="@Model.Numinventaire" class="btn btn-outline-secondary btn-sm">Retour</a>
    </div>
    <div class="card-body">
        <div class="alert alert-info" role="alert">
            Vous avez @Model.CurrentReservationCount / @Model.MaxReservationCount reservations actives.
        </div>

        <form asp-action="Reserve" asp-route-id="@Model.Numinventaire" method="post" class="mb-4">
            @Html.AntiForgeryToken()
            <input asp-for="Numinventaire" type="hidden" />
            <input asp-for="Titre" type="hidden" />
            <input asp-for="BookDateArrivage" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label">Date debut</label>
                    <input asp-for="StartDate" type="date" class="form-control" min="@minReservationDateValue" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label">Date fin</label>
                    <input asp-for="EndDate" type="date" class="form-control" min="@minReservationDateValue" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">Confirmer la reservation</button>
            </div>
        </form>

        <h6>Places deja reservees</h6>

        @if (!Model.Reservations.Any())
        {
            <div class="alert alert-success mb-0" role="alert">Aucune reservation sur cette periode.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Debut</th>
                            <th>Fin</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reservation in Model.Reservations)
                        {
                            <tr>
                                <td>@reservation.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@reservation.EndDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (reservation.Status == ReservationStatus.Active)
                                    {
                                        <span class="badge bg-danger">Active</span>
                                    }
                                    else if (reservation.Status == ReservationStatus.Cancelled)
                                    {
                                        <span class="badge bg-secondary">Annulee</span>
                                    }
                                    else if (reservation.Status == ReservationStatus.Reserved)
                                    {
                                        <span class="badge bg-warning text-dark">Reservee</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Retournee</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
