@model Livre

@{
    ViewData["Title"] = "Modifier livre";
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0"><i class="bx bx-edit me-2"></i>Modifier livre</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Numinventaire" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Numinventaire" class="form-label"></label>
                    <input asp-for="Numinventaire" class="form-control" readonly />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Isbn" class="form-label"></label>
                    <input asp-for="Isbn" class="form-control" />
                    <span asp-validation-for="Isbn" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Titre" class="form-label"></label>
                    <input asp-for="Titre" class="form-control" />
                    <span asp-validation-for="Titre" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Auteur" class="form-label"></label>
                    <input asp-for="Auteur" class="form-control" />
                    <span asp-validation-for="Auteur" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Editeur" class="form-label"></label>
                    <input asp-for="Editeur" class="form-control" />
                    <span asp-validation-for="Editeur" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Datepublication" class="form-label"></label>
                    <input asp-for="Datepublication" class="form-control" type="date" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Datearrivage" class="form-label"></label>
                    <input asp-for="Datearrivage" class="form-control" type="date" />
                </div>
                <div class="col-md-12 mb-3">
                    <label asp-for="Résumé" class="form-label"></label>
                    <textarea asp-for="Résumé" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Résumé" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Cote" class="form-label"></label>
                    <input asp-for="Cote" class="form-control" />
                    <span asp-validation-for="Cote" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}